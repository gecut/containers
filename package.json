{
  "name": "@gecut/containers",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "test": "pnpm build && pnpm -r --workspace-concurrency=1 test",
    "typecheck": "pnpm build && pnpm -r --workspace-concurrency=1 typecheck",
    "catalog:validate": "pnpm --filter @gecut/container-catalog cli validate",
    "catalog:normalize": "pnpm --filter @gecut/container-catalog cli normalize",
    "catalog:graph": "pnpm --filter @gecut/container-catalog cli graph",
    "changes:validate": "pnpm --filter @gecut/container-changes cli validate",
    "changes:list": "pnpm --filter @gecut/container-changes cli list --json",
    "release:plan": "pnpm --filter @gecut/container-release cli plan",
    "release:verify": "pnpm --filter @gecut/container-release cli verify",
    "bake:generate": "pnpm --filter @gecut/container-bake cli generate --write",
    "bake:check": "pnpm --filter @gecut/container-bake cli check",
    "bake:plan": "pnpm --filter @gecut/container-bake cli plan"
  },
  "devDependencies": {
    "@types/node": "25.0.1",
    "typescript": "5.9.3",
    "vitest": "4.0.15"
  },
  "dependencies": {
    "yaml": "2.8.2",
    "zod": "4.2.1"
  }
}
