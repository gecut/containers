gzip            $NGINX_GZIP;
gzip_static     $NGINX_GZIP_STATIC;
gzip_comp_level $NGINX_GZIP_COMP_LEVEL;
gzip_vary       $NGINX_GZIP_VARY;
gzip_min_length $NGINX_GZIP_MIN_LENGTH;
gzip_proxied    any;
gzip_types
    application/javascript
    application/json
    application/ld+json
    application/manifest+json
    application/wasm
    application/xml
    image/svg+xml
    text/css
    text/csv
    text/plain
    text/xml
;
