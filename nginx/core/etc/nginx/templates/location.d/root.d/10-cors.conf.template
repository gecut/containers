add_header 'Access-Control-Allow-Origin' '$NGINX_CORS_ORIGIN' always;
add_header 'Access-Control-Allow-Methods' '$NGINX_CORS_METHODS' always;
add_header 'Access-Control-Allow-Headers' '$NGINX_CORS_HEADERS' always;
add_header 'Access-Control-Max-Age' '$NGINX_CORS_MAXAGE' always;

# Handle OPTIONS requests (preflight requests for complex requests)
if ($request_method = 'OPTIONS') {
  return 204;
}
